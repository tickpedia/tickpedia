{
  "name": "@tickpedia/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./ingest": "./src/ingest/index.ts",
    "./seeds/ticks": "./src/seeds/ticks.ts",
    "./seeds/diseases": "./src/seeds/diseases.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=../.env src/migrate.ts",
    "db:seed": "tsx --env-file=../.env src/seed.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-orm": "^0.38.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^3.0.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0",
    "xlsx": "^0.18.5"
  }
}
