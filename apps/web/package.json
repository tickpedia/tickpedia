{
  "name": "@tickpedia/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && pnpm build:ssr && pnpm build:prerender && pnpm build:aliases && pnpm build:fallback && pnpm build:sitemap && pnpm build:deploy-json",
    "build:ssr": "vite build --ssr src/entry-server.tsx --outDir dist-ssr --emptyOutDir",
    "build:prerender": "tsx scripts/prerender.ts",
    "build:aliases": "tsx scripts/emit-alias-stubs.ts",
    "build:fallback": "tsx scripts/copy-spa-fallback.ts",
    "build:sitemap": "tsx scripts/generate-sitemap.ts",
    "build:deploy-json": "tsx scripts/generate-deploy-json.ts",
    "preview": "vite preview --port 5173",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@semilayer/client": "^1.9.1",
    "@semilayer/core": "^0.1.29",
    "@tickpedia/ui": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.0",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.0.0"
  }
}
