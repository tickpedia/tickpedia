# Tickpedia — local env
# Copy to .env and fill in values. Never commit .env.
# See ../plan/steps/01_bootstrap.md for where each value comes from.

# ── Database ───────────────────────────────────────────────────────
# Local development uses the Postgres in docker/docker-compose.yml.
#   docker compose -f docker/docker-compose.yml up -d
#   DATABASE_URL=postgresql://tickpedia:tickpedia@localhost:5432/tickpedia
#
# Production / hosted dev uses Neon. Use the *pooled* connection string
# (the one with `-pooler` in the host) for serverless callers (Vercel,
# the public site); the unpooled one is fine for migrations.
DATABASE_URL=postgresql://tickpedia:tickpedia@localhost:5432/tickpedia
# DATABASE_URL=postgresql://user:password@ep-xyz.us-east-2.aws.neon.tech/tickpedia?sslmode=require

# ── Public site (apps/web → tickpedia.com via GitHub Pages) ────────
PUBLIC_SITE_URL=http://localhost:5173

# ── Admin site (apps/admin → admin.tickpedia.com via Vercel) ───────
ADMIN_SITE_URL=http://localhost:3001

# ── Clerk auth (admin only) ────────────────────────────────────────
# Both keys come from the Clerk dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Comma-separated allowlist of admin emails. Anyone signing in with an
# email outside this list is hard-rejected by middleware. Two people only.
ADMIN_ALLOWED_EMAILS=person-one@example.com,person-two@example.com

# Where Clerk redirects after sign-in. Leave defaults unless you know why.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── SemiLayer (Beam client + codegen) ──────────────────────────────
# Service URL of your SemiLayer deployment. For local dogfooding:
#   http://localhost:3001 (when running ../../semilayer/semilayer locally)
# For SaaS: https://api.semilayer.com
SEMILAYER_SERVICE_URL=http://localhost:3001

# Service key (sk_dev_..., sk_live_...) — from `semilayer keys create`
# or the SemiLayer console. Used by codegen + server-side reads.
SEMILAYER_API_KEY=sk_dev_REPLACE_ME

# Public key (pk_live_...) — embedded in the browser bundle. Read-only,
# scoped to whatever lenses you've granted "public" access.
NEXT_PUBLIC_SEMILAYER_PUBLIC_KEY=pk_live_REPLACE_ME

# Ingest key (ik_..., write-only). Wired into Postgres GUC settings so
# the triggers in db/sql/semilayer-triggers.sql can POST to
# /v1/ingest/<lens> on row changes. Mint via:
#   pnpm exec semilayer keys create --type ingest --label <name>
SEMILAYER_INGEST_KEY=ik_prod_REPLACE_ME
